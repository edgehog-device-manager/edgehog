{
  "interface_name": "io.edgehog.devicemanager.fileTransfer.Progress",
  "version_major": 0,
  "version_minor": 1,
  "type": "datastream",
  "ownership": "device",
  "aggregation": "object",
  "description": "Progress of a file transfer.",
  "doc": "If the request enabled progress reporting, the device will send the progress of the operation.",
  "mappings": [
    {
      "endpoint": "/request/id",
      "type": "string",
      "database_retention_policy": "use_ttl",
      "database_retention_ttl": 3600,
      "description": "Transfer ID for the file."
    },
    {
      "endpoint": "/request/type",
      "type": "string",
      "database_retention_policy": "use_ttl",
      "database_retention_ttl": 3600,
      "description": "Direction of the file transfer",
      "doc": "Specifies the direction of the transfer. Allowed values: 'server_to_device' or 'device_to_server'."
    },
    {
      "endpoint": "/request/bytes",
      "type": "longinteger",
      "database_retention_policy": "use_ttl",
      "database_retention_ttl": 3600,
      "description": "Progress of the transfer in number of bytes transferred."
    },
    {
      "endpoint": "/request/totalBytes",
      "type": "longinteger",
      "database_retention_policy": "use_ttl",
      "database_retention_ttl": 3600,
      "description": "Total size of the transfer.",
      "doc": "Reports the total number of bytes that have to be transferred. If the total size is not known this field contains a value of '-1'."
    }
  ]
}
