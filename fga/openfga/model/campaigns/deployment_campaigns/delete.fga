module deployment_delete_campaign

type deployment_delete_campaign
  relations
    define tenant:      [tenant]
    define alias:       [deployment_delete_campaign]

    define blocklisted: [user, group#member] or deployment_delete_campaigns_blocklisted from tenant

    define computed_can_view: can_edit_params or can_pause_resume or can_delete or can_view_deployment_delete_campaigns from tenant

    define can_view:              ([user, group#member] or computed_can_view) but not blocklisted
    define can_edit_params:       ([user, group#member] or can_edit_deployment_delete_campaigns_params from tenant) but not blocklisted
    define can_pause_resume:  ([user, group#member] or can_pause_resume_deployment_delete_campaigns from tenant) but not blocklisted
    define can_delete:            ([user, group#member] or can_delete_deployment_delete_campaigns from tenant) but not blocklisted

extend type tenant
  relations
    define deployment_delete_campaigns_blocklisted: [user, group#member] or deployment_campaigns_blocklisted

    # Deployment delete
    define computed_can_view_deployment_delete_campaigns:     can_view_all_campaigns or can_launch_deployment_delete_campaigns or can_schedule_deployment_delete_campaigns or can_edit_deployment_delete_campaigns_params or can_pause_resume_deployment_delete_campaigns

    define can_view_deployment_delete_campaigns:              ([user, group#member] or computed_can_view_deployment_delete_campaigns) but not deployment_delete_campaigns_blocklisted
    define can_launch_deployment_delete_campaigns:            ([user, group#member] or can_launch_deployment_campaigns) but not deployment_delete_campaigns_blocklisted
    define can_schedule_deployment_delete_campaigns:          ([user, group#member] or can_schedule_deployment_campaigns) but not deployment_delete_campaigns_blocklisted
    define can_edit_deployment_delete_campaigns_params:       ([user, group#member] or can_edit_deployment_campaigns_params) but not deployment_delete_campaigns_blocklisted
    define can_pause_resume_deployment_delete_campaigns:  ([user, group#member] or can_pause_resume_deployment_campaigns) but not deployment_delete_campaigns_blocklisted
    define can_delete_deployment_delete_campaigns:            ([user, group#member] or can_delete_deployment_campaigns) but not deployment_delete_campaigns_blocklisted
