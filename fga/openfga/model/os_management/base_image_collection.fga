module base_image_collection

## ---------------------------------------------------------------------------
## BASE IMAGE COLLECTION  (tenant-wide resource)
##
## A base image collection owns its base images (parent-child).
## ---------------------------------------------------------------------------

type base_image_collection
  relations
    define tenant: [tenant]
    define alias:   [base_image_collection]

    define blocklisted:  [user, group#member] or base_image_collection_blocklisted from tenant

    define computed_can_view: can_edit or can_delete or can_view_images or can_add_images or can_remove_images or can_edit_images or can_view_all_base_image_collections from tenant

    define can_view:            ([user, group#member] or computed_can_view) but not blocklisted
    define can_edit:            ([user, group#member] or can_edit_all_base_image_collections from tenant) but not blocklisted
    define can_delete:          ([user, group#member] or can_delete_all_base_image_collections from tenant) but not blocklisted
    define can_view_images:     ([user, group#member] or can_view_base_images_in_all_collections from tenant) but not blocklisted
    define can_add_images:      ([user, group#member] or can_add_base_images_in_all_collections from tenant) but not blocklisted
    define can_remove_images:   ([user, group#member] or can_remove_base_images_in_all_collections from tenant) but not blocklisted
    define can_edit_images:     ([user, group#member] or can_edit_base_images_in_all_collections from tenant) but not blocklisted

extend type tenant
  relations
    define base_image_collection_blocklisted: [user, group#member] or blocklisted

    define computed_can_view_all_base_image_collections:  can_edit_all_base_image_collections or can_delete_all_base_image_collections

    define can_create_base_image_collections:           ([user, group#member]) but not base_image_collection_blocklisted
    define can_view_all_base_image_collections:         ([user, group#member] or computed_can_view_all_base_image_collections) but not base_image_collection_blocklisted
    define can_edit_all_base_image_collections:         ([user, group#member]) but not base_image_collection_blocklisted
    define can_delete_all_base_image_collections:       ([user, group#member]) but not base_image_collection_blocklisted
    define can_view_base_images_in_all_collections:     ([user, group#member]) but not base_image_collection_blocklisted
    define can_add_base_images_in_all_collections:      ([user, group#member]) but not base_image_collection_blocklisted
    define can_remove_base_images_in_all_collections:   ([user, group#member]) but not base_image_collection_blocklisted
    define can_edit_base_images_in_all_collections:     ([user, group#member]) but not base_image_collection_blocklisted
